---
// BaseLayout.astro — shared wrapper for all pages
interface Props {
  title: string;
  description?: string;
  activePage?: string;
  extraCss?: string[]; // Additional page-specific CSS files
}

const { 
  title, 
  description = "A Death Note-themed cybersecurity blog by vaLak", 
  activePage = '',
  extraCss = []
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="author" content="vaLak" />
  <title>{title} — The False Positive</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' fill='%231A1D1A'/><text y='.9em' font-size='85' font-family='serif' font-weight='900' font-style='italic' fill='%23E1E9E8'>L</text></svg>" />

  <!-- Core CSS -->
  <link rel="stylesheet" href="/styles/theme.css" />
  <link rel="stylesheet" href="/styles/layout.css" />

  <!-- Per-page CSS -->
  {extraCss.map(href => <link rel="stylesheet" href={href} />)}
</head>
<body>

  <!-- Ink Drop Overlay -->
  <div id="ink-overlay" aria-hidden="true"></div>

  <!-- Top Navigation -->
  <nav id="topnav" role="navigation" aria-label="Main navigation">
    <a href="/" class="nav-brand" aria-label="The False Positive — Home">
      <span class="nav-brand-name">The False Positive</span>
    </a>
    <div class="nav-spacer"></div>
    <ul class="nav-links" role="list">
      <li><a href="/about" class:list={{ active: activePage === 'about' }} id="nav-about">About</a></li>
      <li><a href="/pentest" class:list={{ active: activePage === 'pentest' }} id="nav-pentest">Handbook</a></li>
      <li><a href="/ctf" class:list={{ active: activePage === 'ctf' }} id="nav-ctf">Writeups</a></li>
      <li><a href="/arsenal" class:list={{ active: activePage === 'arsenal' }} id="nav-arsenal">Toolkit</a></li>
      <li><a href="/news" class:list={{ active: activePage === 'news' }} id="nav-news">Intel</a></li>
    </ul>
    <button class="nav-search-btn" id="search-trigger" aria-label="Open search" aria-keyshortcuts="Control+K">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      Search
      <kbd class="shortcut">Ctrl K</kbd>
    </button>
    <a href="https://github.com/Atharva-G100" target="_blank" rel="noopener" class="nav-icon-link" aria-label="GitHub profile" id="nav-github">
      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
      </svg>
    </a>
    <button class="nav-hamburger" id="nav-hamburger" aria-label="Toggle menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </nav>

  <!-- Search Modal -->
  <div id="search-modal" role="dialog" aria-label="Search" aria-modal="true">
    <div class="search-box">
      <div class="search-input-wrap">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        <input type="text" id="search-input" placeholder="Search the notebook..." autocomplete="off" aria-label="Search" />
      </div>
      <div id="search-results" role="listbox" aria-label="Search results">
        <div class="search-empty">Start typing to search the notebook...</div>
      </div>
      <div class="search-footer">
        <span>↑↓ navigate</span>
        <span>↵ open</span>
        <span>Esc close</span>
      </div>
    </div>
  </div>

  <!-- Page Content -->
  <slot />

  <!-- Footer -->
  <footer id="site-footer" role="contentinfo">
    <p class="footer-text">
      &copy; <span id="footer-year"></span> vaLak &middot; The False Positive
    </p>
  </footer>

  <!-- Shared script -->
  <script src="/scripts/main.js" is:inline></script>
</body>
</html>
