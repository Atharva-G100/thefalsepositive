<script is:inline>
  // --- UI Interactions ───
  // Top View Switching (Local vs Satellite)
  document.querySelectorAll('.hud-tab').forEach(tab => {
    tab.addEventListener('click', (e) => {
      document.querySelectorAll('.hud-tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.hud-view').forEach(v => v.classList.remove('active'));
      
      const selectedTab = e.currentTarget;
      selectedTab.classList.add('active');
      const viewId = selectedTab.getAttribute('data-view');
      document.getElementById(viewId).classList.add('active');
    });
  });

  // Sidebar Tool Panel Switching
  document.querySelectorAll('.arsenal-nav-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      const activeBtn = e.currentTarget;
      
      // Remove active from all
      document.querySelectorAll('.arsenal-nav-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.arsenal-tool-panel').forEach(p => p.classList.remove('active'));
      
      // Add active to clicked
      activeBtn.classList.add('active');
      const targetId = activeBtn.getAttribute('data-target');
      const targetPanel = document.getElementById(targetId);
      
      if (targetPanel) {
        targetPanel.classList.add('active');
        
        // Smooth scroll to the main content container top so the tool is "in front" (great for UX/mobile)
        const mainContainer = document.querySelector('.arsenal-main');
        if (mainContainer) {
          const yOffset = -80; // offset for nav height
          const y = mainContainer.getBoundingClientRect().top + window.pageYOffset + yOffset;
          window.scrollTo({ top: y, behavior: 'smooth' });
        }
      }
    });
  });

  // Toasts & Copy
  function showToast(message) {
    const container = document.getElementById('toast-container');
    const toast = document.createElement('div');
    toast.className = 'toast';
    toast.innerText = message;
    container.appendChild(toast);
    setTimeout(() => {
      toast.style.opacity = '0';
      toast.style.transition = 'opacity 0.3s';
      setTimeout(() => toast.remove(), 300);
    }, 2000);
  }

  function copyResult(elementId) {
    const el = document.getElementById(elementId);
    if (!el || el.classList.contains('empty')) return;
    
    // We only want the text, not the button text
    const textNode = Array.from(el.childNodes).filter(node => node.nodeType === Node.TEXT_NODE).map(node => node.textContent).join('');
    
    navigator.clipboard.writeText(textNode).then(() => {
      showToast('Copied to clipboard');
    });
  }

  function setOutput(elementId, value) {
    const el = document.getElementById(elementId);
    if (!value) {
      el.classList.add('empty');
      // Keep the button if it exists
      const btnHtml = el.innerHTML.includes('<button') ? '<button class="copy-btn" onclick="copyResult(\'' + elementId + '\')">Copy</button>' : '';
      el.innerHTML = '...' + btnHtml;
      return;
    }
    el.classList.remove('empty');
    const btnHtml = el.innerHTML.includes('<button') ? '<button class="copy-btn" onclick="copyResult(\'' + elementId + '\')">Copy</button>' : '';
    el.innerHTML = value + btnHtml;
  }

  // --- Tool: Decoder Ring ---
  function decodeRun(action) {
    const input = document.getElementById('decoder-in').value;
    if (!input) { setOutput('decoder-out', ''); return; }
    
    let out = '';
    try {
      if (action === 'b64enc') out = btoa(input);
      else if (action === 'b64dec') out = atob(input);
      else if (action === 'urlenc') out = encodeURIComponent(input);
      else if (action === 'urldec') out = decodeURIComponent(input);
      else if (action === 'hexenc') {
        out = input.split('').map(c => c.charCodeAt(0).toString(16).padStart(2, '0')).join(' ');
      }
      else if (action === 'hexdec') {
        const hex = input.replace(/[^0-9a-fA-F]/g, '');
        for (let i = 0; i < hex.length; i += 2) {
          out += String.fromCharCode(parseInt(hex.substr(i, 2), 16));
        }
      }
      setOutput('decoder-out', out);
    } catch (e) {
      setOutput('decoder-out', 'Error: Invalid input for this operation.');
    }
  }

  // --- Tool: ROT Cipher ---
  function rotRun(mode) {
    const input = document.getElementById('rot-in').value;
    if (!input) { setOutput('rot-out', ''); return; }
    
    function shiftChar(c, shift) {
      const code = c.charCodeAt(0);
      if (code >= 65 && code <= 90) return String.fromCharCode(((code - 65 + shift) % 26) + 65);
      if (code >= 97 && code <= 122) return String.fromCharCode(((code - 97 + shift) % 26) + 97);
      return c;
    }

    if (mode === 'encode' || mode === 'shift') {
      const s = parseInt(document.getElementById('rot-shift').value) || 0;
      const out = input.split('').map(c => shiftChar(c, s)).join('');
      setOutput('rot-out', out);
    } else if (mode === 'decode') {
      const s = parseInt(document.getElementById('rot-shift').value) || 0;
      const out = input.split('').map(c => shiftChar(c, 26 - (s % 26))).join('');
      setOutput('rot-out', out);
    } else if (mode === 'auto') {
      const alphaOnly = input.replace(/[^A-Za-z]/g, '').toUpperCase();
      if (alphaOnly.length < 4) { setOutput('rot-out', 'Need more text for auto-decode'); return; }
      const engFreq = [0.08167, 0.01492, 0.02782, 0.04253, 0.12702, 0.02228, 0.02015, 0.06094, 0.06966, 0.00153, 0.00772, 0.04025, 0.02406, 0.06749, 0.07507, 0.01929, 0.00095, 0.05987, 0.06327, 0.09056, 0.02758, 0.00978, 0.02360, 0.00150, 0.01974, 0.00074];
      
      let bestShift = 0;
      let minChi = Infinity;
      for (let shift = 0; shift < 26; shift++) {
        let decoded = alphaOnly.split('').map(c => shiftChar(c, 26 - shift)).join('');
        let counts = new Array(26).fill(0);
        for(let i = 0; i < decoded.length; i++) counts[decoded.charCodeAt(i) - 65]++;
        
        let chi = 0;
        for(let i = 0; i < 26; i++) {
          let expected = alphaOnly.length * engFreq[i];
          if(expected > 0) chi += Math.pow(counts[i] - expected, 2) / expected;
        }
        if (chi < minChi) {
          minChi = chi;
          bestShift = shift;
        }
      }
      
      const decodedText = input.split('').map(c => shiftChar(c, 26 - bestShift)).join('');
      document.getElementById('rot-shift').value = bestShift;
      setOutput('rot-out', `[Best Shift Found: ${bestShift}]\n\n${decodedText}`);
    } else {
      let out = '';
      for (let s = 1; s <= 25; s++) {
        out += `[Shift ${s.toString().padStart(2, '0')}]: ${input.split('').map(c => shiftChar(c, s)).join('')}\n`;
      }
      setOutput('rot-out', out);
    }
  }

  // --- Tool: Vigenère Cipher ---
  function vigenereRun(mode) {
    const input = document.getElementById('vigenere-in').value;
    
    if (mode === 'auto') {
      const alphaOnly = input.replace(/[^A-Za-z]/g, '').toUpperCase();
      if (alphaOnly.length < 8) { setOutput('vigenere-out', 'Need more text for auto-decode (at least 8-10 chars).'); return; }
      
      const engFreq = [0.08167, 0.01492, 0.02782, 0.04253, 0.12702, 0.02228, 0.02015, 0.06094, 0.06966, 0.00153, 0.00772, 0.04025, 0.02406, 0.06749, 0.07507, 0.01929, 0.00095, 0.05987, 0.06327, 0.09056, 0.02758, 0.00978, 0.02360, 0.00150, 0.01974, 0.00074];
      let bestLen = 1;
      let maxScore = -Infinity;

      for (let l = 1; l <= Math.min(20, alphaOnly.length / 2); l++) {
        let avgIoc = 0;
        let validCols = 0;
        for (let i = 0; i < l; i++) {
          let counts = new Array(26).fill(0);
          let tot = 0;
          for (let j = i; j < alphaOnly.length; j += l) {
            counts[alphaOnly.charCodeAt(j) - 65]++;
            tot++;
          }
          if (tot > 1) {
            let sum = 0;
            for (let c of counts) sum += c * (c - 1);
            avgIoc += sum / (tot * (tot - 1));
            validCols++;
          }
        }
        if (validCols > 0) {
          avgIoc /= validCols;
          if (avgIoc > maxScore) { maxScore = avgIoc; bestLen = l; }
        }
      }

      let key = '';
      for (let i = 0; i < bestLen; i++) {
        let counts = new Array(26).fill(0);
        let tot = 0;
        for (let j = i; j < alphaOnly.length; j += bestLen) {
          counts[alphaOnly.charCodeAt(j) - 65]++;
          tot++;
        }
        let bestShift = 0;
        let minChi = Infinity;
        for (let shift = 0; shift < 26; shift++) {
          let chi = 0;
          for (let c = 0; c < 26; c++) {
            let obs = counts[(c + shift) % 26];
            let exp = tot * engFreq[c];
            if (exp > 0) chi += Math.pow(obs - exp, 2) / exp;
          }
          if (chi < minChi) { minChi = chi; bestShift = shift; }
        }
        key += String.fromCharCode(bestShift + 65);
      }

      document.getElementById('vigenere-key').value = key;
      vigenereRun('decode');
      
      const decodedText = document.getElementById('vigenere-out').innerText;
      setOutput('vigenere-out', `<div style="margin-bottom:0.5rem;color:var(--accent);">Cracked Key: <b>${key}</b> (Length: ${bestLen})</div>` + decodedText);
      return;
    }

    const key = document.getElementById('vigenere-key').value.toUpperCase().replace(/[^A-Z]/g, '');
    if (!input || !key) { setOutput('vigenere-out', 'Input and alphabetic key required.'); return; }

    let out = '';
    let keyIdx = 0;

    for (let i = 0; i < input.length; i++) {
      const char = input[i];
      const code = char.charCodeAt(0);
      const isUpper = (code >= 65 && code <= 90);
      const isLower = (code >= 97 && code <= 122);

      if (isUpper || isLower) {
        const base = isUpper ? 65 : 97;
        const p = code - base;
        const k = key.charCodeAt(keyIdx % key.length) - 65;
        
        let c;
        if (mode === 'encode') {
          c = (p + k) % 26;
        } else {
          c = (p - k + 26) % 26;
        }
        
        out += String.fromCharCode(c + base);
        keyIdx++;
      } else {
        out += char;
      }
    }
    setOutput('vigenere-out', out);
  }

  // --- Tool: XOR Tool ---
  function xorRun() {
    let input = document.getElementById('xor-in').value.trim();
    let key = document.getElementById('xor-key').value.trim();
    if (!input || !key) return;

    // Detect if inputs are hex (remove spaces and check)
    const isHex = (str) => /^[0-9a-fA-F]+$/.test(str.replace(/\s/g, ''));
    
    let inBytes = [];
    if (isHex(input)) {
      const hex = input.replace(/\s/g, '');
      for(let i=0; i<hex.length; i+=2) inBytes.push(parseInt(hex.substr(i,2), 16));
    } else {
      for(let i=0; i<input.length; i++) inBytes.push(input.charCodeAt(i));
    }

    let keyBytes = [];
    if (isHex(key)) {
      const hex = key.replace(/\s/g, '');
      for(let i=0; i<hex.length; i+=2) keyBytes.push(parseInt(hex.substr(i,2), 16));
    } else {
      for(let i=0; i<key.length; i++) keyBytes.push(key.charCodeAt(i));
    }

    if(keyBytes.length === 0) return;

    let outHex = [];
    let outAscii = '';
    for(let i=0; i<inBytes.length; i++) {
      let x = inBytes[i] ^ keyBytes[i % keyBytes.length];
      outHex.push(x.toString(16).padStart(2, '0'));
      outAscii += (x >= 32 && x <= 126) ? String.fromCharCode(x) : '.';
    }

    setOutput('xor-out-hex', outHex.join(' '));
    setOutput('xor-out-ascii', outAscii);
  }

  // --- Tool: Hash Generator ---
  async function hashRun() {
    const input = document.getElementById('hashgen-in').value;
    if (!input) {
      setOutput('hashgen-md5', '');
      setOutput('hashgen-sha1', '');
      setOutput('hashgen-sha256', '');
      setOutput('hashgen-sha512', '');
      return;
    }

    // MD5 via CryptoJS
    if (window.CryptoJS) {
      setOutput('hashgen-md5', CryptoJS.MD5(input).toString());
    }

    // SHA family via WebCrypto
    const encoder = new TextEncoder();
    const data = encoder.encode(input);

    const hashToHex = async (algo, outId) => {
      const hashBuffer = await crypto.subtle.digest(algo, data);
      const hashArray = Array.from(new Uint8Array(hashBuffer));
      const hashHex = hashArray.map(b => b.toString(16).padStart(2, '0')).join('');
      setOutput(outId, hashHex);
    };

    hashToHex('SHA-1', 'hashgen-sha1');
    hashToHex('SHA-256', 'hashgen-sha256');
    hashToHex('SHA-512', 'hashgen-sha512');
  }

  // --- Tool: Hash Identifier ---
  function hashIdRun() {
    const input = document.getElementById('hashid-in').value.trim();
    if (!input) { setOutput('hashid-out', ''); return; }

    const len = input.length;
    const isHex = /^[0-9a-fA-F]+$/.test(input);
    const isB64 = /^[a-zA-Z0-9+/]+={0,2}$/.test(input);
    const isNum = /^[0-9]+$/.test(input);
    
    let matches = [];

    if (/^[0-9a-fA-F]{32}:[0-9a-fA-F]{32}$/.test(input)) {
      matches.push('Windows LM/NTLM Pair');
    }
    if (/^[A-Za-z0-9_-]+\.[A-Za-z0-9_-]+\.[A-Za-z0-9_-]+$/.test(input)) {
      matches.push('JSON Web Token (JWT)');
    }
    
    if (isHex) {
      if (len === 32) matches.push('MD5', 'MD4', 'NTLM', 'MD2');
      if (len === 40) matches.push('SHA-1', 'RIPEMD-160');
      if (len === 56) matches.push('SHA-224', 'SHA3-224');
      if (len === 64) matches.push('SHA-256', 'RIPEMD-256', 'SHA3-256');
      if (len === 96) matches.push('SHA-384');
      if (len === 128) matches.push('SHA-512', 'Whirlpool');
    }
    
    if (input.startsWith('$1$')) matches.push('MD5 Crypt');
    if (input.startsWith('$2a$') || input.startsWith('$2b$') || input.startsWith('$2y$')) matches.push('Bcrypt');
    if (input.startsWith('$5$')) matches.push('SHA-256 Crypt');
    if (input.startsWith('$6$')) matches.push('SHA-512 Crypt');
    
    if (matches.length > 0) {
      const el = document.getElementById('hashid-out');
      el.classList.remove('empty');
      el.innerHTML = matches.map(m => `> ${m}`).join('<br>');
    } else {
      setOutput('hashid-out', 'No definitive matches found for this length/format.');
    }
  }

  // --- Tool: Magic Bytes ---
  function magicRun() {
    let input = document.getElementById('magic-in').value.trim().toUpperCase().replace(/\s/g, '');
    if (!input) { setOutput('magic-out', ''); return; }

    const sigs = [
      { hex: '89504E47', type: 'PNG Image' },
      { hex: 'FFD8FF', type: 'JPEG Image' },
      { hex: '25504446', type: 'PDF Document' },
      { hex: '504B0304', type: 'ZIP Archive' },
      { hex: '7F454C46', type: 'ELF Executable (Linux)' },
      { hex: '47494638', type: 'GIF Image' },
      { hex: '4D5A', type: 'PE Executable (Windows DOS/EXE)' },
      { hex: '377ABCAF271C', type: '7z Archive' },
      { hex: '526172211A07', type: 'RAR Archive' },
      { hex: '00000018667479706D703432', type: 'MP4 Video' },
      { hex: 'CAFEBABE', type: 'Java Class File' },
    ];

    let match = null;
    for (let s of sigs) {
      if (input.startsWith(s.hex)) {
        match = s; break;
      }
    }

    if (match) {
      setOutput('magic-out', `<span style="color: var(--red-bright)">Found:</span> ${match.type}`);
    } else {
      setOutput('magic-out', 'Unknown or incomplete signature.');
    }
  }

  // --- Tool: Timestamp Converter ---
  function timeUnixRun() {
    const input = document.getElementById('time-unix-in').value;
    if (!input) { setOutput('time-unix-out', ''); return; }
    
    // JS dates need ms
    let ts = parseInt(input);
    if(input.length <= 10) ts *= 1000;
    
    const d = new Date(ts);
    if (isNaN(d.getTime())) { setOutput('time-unix-out', 'Invalid timestamp'); return; }

    const now = new Date();
    const diff = Math.floor((now - d) / 1000);
    let diffStr = '';
    if (diff > 0) {
      if (diff < 60) diffStr = `${diff} seconds ago`;
      else if (diff < 3600) diffStr = `${Math.floor(diff/60)} minutes ago`;
      else if (diff < 86400) diffStr = `${Math.floor(diff/3600)} hours ago`;
      else diffStr = `${Math.floor(diff/86400)} days ago`;
    } else {
      diffStr = 'In the future';
    }

    setOutput('time-unix-out', `UTC:   ${d.toUTCString()}\nLocal: ${d.toString()}\nTime:  ${diffStr}`);
  }

  function timeDateRun() {
    const input = document.getElementById('time-date-in').value;
    if (!input) { setOutput('time-date-out', ''); return; }
    const d = new Date(input);
    const ts = Math.floor(d.getTime() / 1000);
    setOutput('time-date-out', ts.toString());
  }

  // --- Tool: IP Converter ---
  function ipRun() {
    const input = document.getElementById('ip-in').value.trim();
    if (!input) { 
      setOutput('ip-out-hex', ''); setOutput('ip-out-int', ''); setOutput('ip-out-bin', '');
      return; 
    }

    const parts = input.split('.');
    if (parts.length !== 4) return;
    
    let isV4 = true;
    let bytes = [];
    for(let p of parts) {
      const num = parseInt(p);
      if(isNaN(num) || num < 0 || num > 255) isV4 = false;
      bytes.push(num);
    }
    
    if(!isV4) return;

    // Hex
    const hex = '0x' + bytes.map(b => b.toString(16).padStart(2, '0')).join('');
    // Int
    const int = (bytes[0] << 24 | bytes[1] << 16 | bytes[2] << 8 | bytes[3]) >>> 0;
    // Bin
    const bin = bytes.map(b => b.toString(2).padStart(8, '0')).join('.');

    setOutput('ip-out-hex', hex);
    setOutput('ip-out-int', int.toString());
    setOutput('ip-out-bin', bin);
  }

  // --- Tool: CIDR Calculator ---
  function cidrRun() {
    const input = document.getElementById('cidr-in').value.trim();
    if (!input) { setOutput('cidr-out', ''); return; }

    const [ipStr, cidrStr] = input.split('/');
    if (!ipStr || !cidrStr) return;
    
    const cidr = parseInt(cidrStr);
    if (isNaN(cidr) || cidr < 0 || cidr > 32) return;

    const parts = ipStr.split('.');
    if (parts.length !== 4) return;
    
    const ipInt = (parseInt(parts[0]) << 24 | parseInt(parts[1]) << 16 | parseInt(parts[2]) << 8 | parseInt(parts[3])) >>> 0;
    
    // Mask
    const maskInt = cidr === 0 ? 0 : (~0 << (32 - cidr)) >>> 0;
    
    // Network Address (IP AND Mask)
    const netInt = (ipInt & maskInt) >>> 0;
    
    // Broadcast Address (Network OR Inverted Mask)
    const bcastInt = (netInt | (~maskInt)) >>> 0;

    const intToIp = (i) => `${(i >>> 24) & 255}.${(i >>> 16) & 255}.${(i >>> 8) & 255}.${i & 255}`;

    let totalHosts = 0;
    let firstHost = 'N/A';
    let lastHost = 'N/A';

    if (cidr === 32) {
      totalHosts = 1;
      firstHost = intToIp(netInt);
      lastHost = intToIp(netInt);
    } else if (cidr === 31) {
      totalHosts = 2;
      firstHost = intToIp(netInt);
      lastHost = intToIp(bcastInt);
    } else {
      totalHosts = Math.pow(2, 32 - cidr) - 2;
      firstHost = intToIp(netInt + 1);
      lastHost = intToIp(bcastInt - 1);
    }

    let out = `Network ID:    ${intToIp(netInt)}\n`;
    out += `Subnet Mask:   ${intToIp(maskInt)}\n`;
    out += `Broadcast IP:  ${intToIp(bcastInt)}\n`;
    out += `First Host:    ${firstHost}\n`;
    out += `Last Host:     ${lastHost}\n`;
    out += `Total Hosts:   ${totalHosts}`;

    const el = document.getElementById('cidr-out');
    el.classList.remove('empty');
    el.innerHTML = out;
  }

  // --- Tool: Payload Drop ---
  function filterPayloads() {
    const q = document.getElementById('payload-search').value.toLowerCase();
    const categories = document.querySelectorAll('.payload-category');
    
    categories.forEach(cat => {
      let hasMatch = false;
      const items = cat.querySelectorAll('.payload-item');
      
      // Never hide the static info items in IDOR section
      if(cat.dataset.category === 'Open Redirect & IDOR') {
         // check if there's any copyable payload match
         items.forEach(item => {
           if(item.querySelector('button')) {
             if(item.innerText.toLowerCase().includes(q)) {
               item.style.display = 'flex';
               hasMatch = true;
             } else {
               item.style.display = 'none';
             }
           } else {
             // always show tips if category is shown
             item.style.display = 'flex';
           }
         });
         // Show category if q is empty, or if matched
         cat.style.display = (q === '' || hasMatch) ? 'block' : 'none';
         return;
      }

      items.forEach(item => {
        const text = item.innerText.toLowerCase();
        if (text.includes(q)) {
          item.style.display = 'flex';
          hasMatch = true;
        } else {
          item.style.display = 'none';
        }
      });

      if (hasMatch || q === '') {
        cat.style.display = 'block';
      } else {
        cat.style.display = 'none';
      }
    });
  }

  function copyPayload(btn) {
    const codeEl = btn.previousElementSibling;
    const text = codeEl.innerText;
    navigator.clipboard.writeText(text).then(() => {
      showToast('Payload copied');
    });
  }

  function copyTemplatePayload(btn) {
    const codeEl = btn.previousElementSibling;
    const template = codeEl.getAttribute('data-template');
    const inputs = codeEl.querySelectorAll('input');
    
    let finalPayload = template;
    inputs.forEach((input, index) => {
      // If user typed nothing, use placeholder as fallback
      const val = input.value || input.placeholder || '';
      finalPayload = finalPayload.replace(`$$${index}$$`, val);
    });

    navigator.clipboard.writeText(finalPayload).then(() => {
      showToast('Payload generated & copied');
    });
  }

</script>
