---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout 
  title="About vaLak" 
  description="Threat actor profile and intelligence dossier."
  activePage="about"
  extraCss={['/styles/about.css']}
>
  <!-- Visible Parallax Background -->
  <div class="parallax-container">
    
    <!-- Deepest Layer: The Monitor -->
    <div class="parallax-layer parallax-0" data-speed="0.05">
      <div class="monitor-frame">
        <img src="/gifs/L%20logo.gif" alt="L Monitor" class="monitor-gif" />
      </div>
    </div>

    <div class="parallax-layer parallax-1" data-speed="0.2">
      <div class="p-box p-large"></div>
    </div>
    <div class="parallax-layer parallax-2" data-speed="0.5">
      <div class="p-box p-medium"></div>
    </div>
    <div class="parallax-layer parallax-3" data-speed="0.1">
      <div class="p-line"></div>
    </div>
    <div class="parallax-layer parallax-4" data-speed="0.35">
      <div class="p-box p-small"></div>
    </div>
  </div>

  <div class="about-container">
    
    <!-- Hero Section -->
    <header class="about-hero fade-up">
      <div class="hero-symbol">[ ]</div>
      <div class="hero-title">Threat Actor: vaLak</div>
    </header>

    <!-- Biography (Identity Reveal) -->
    <section class="dossier-section">
      <h2 class="section-title fade-up" data-scramble="IDENTITY FILE">IDENTITY FILE</h2>
      
      <div class="identity-card fade-up">
        <div class="identity-header">
          <span class="status-indicator"></span> [ ALIAS "vaLak" DECLASSIFIED ]
        </div>
        <div class="identity-details">
          <div class="detail-row"><span class="detail-label">Real Name:</span> <span class="detail-value">Atharva Gawas</span></div>
          <div class="detail-row"><span class="detail-label">Designation:</span> <span class="detail-value">Cybersecurity Student · Jr. Penetration Tester</span></div>
          <div class="detail-row"><span class="detail-label">Base of Ops:</span> <span class="detail-value">Navi Mumbai, India</span></div>
          <div class="detail-row"><span class="detail-label">Core Focus:</span> <span class="detail-value">Offensive Security, Web App Sec, Digital Forensics</span></div>
        </div>
      </div>

      <h3 class="subsection-title fade-up">WHY I BREAK THINGS</h3>
      <p class="dossier-text fade-up">
        Driven by curiosity and a relentless desire to understand how systems operate beneath the surface. Practical experience built through hands-on labs, independent research, and global CTF competitions. 
      </p>
      <p class="dossier-text fade-up">
        Primary objective: discover weaknesses, apply ethical hacking methodologies, and engineer stronger, more resilient architectures. The terminal is always active.
      </p>
    </section>

    <!-- Arsenal (Tech Stack) -->
    <section class="dossier-section">
      <h2 class="section-title fade-up" data-scramble="ARSENAL">ARSENAL</h2>
      <div class="arsenal-grid fade-up">
        
        <div class="arsenal-category fade-up">
          <h3>Languages</h3>
          <div class="arsenal-tags">
            <span class="arsenal-tag">Python</span>
            <span class="arsenal-tag">C</span>
            <span class="arsenal-tag">JavaScript</span>
            <span class="arsenal-tag">Bash</span>
          </div>
        </div>

        <div class="arsenal-category fade-up">
          <h3>Offensive Tools</h3>
          <div class="arsenal-tags">
            <span class="arsenal-tag">Burp Suite</span>
            <span class="arsenal-tag">Metasploit</span>
            <span class="arsenal-tag">Nmap</span>
            <span class="arsenal-tag">OWASP ZAP</span>
            <span class="arsenal-tag">OpenVAS</span>
            <span class="arsenal-tag">Wireshark</span>
            <span class="arsenal-tag">Ghidra</span>
          </div>
        </div>

        <div class="arsenal-category fade-up">
          <h3>Certifications</h3>
          <div class="arsenal-tags">
            <span class="arsenal-tag">THM: Jr. Penetration Tester</span>
            <span class="arsenal-tag">APIsec Certified Practitioner</span>
            <span class="arsenal-tag">Udemy: Applied Ethical Hacking</span>
            <span class="arsenal-tag">Infosys: Pentesting with Metasploit</span>
            <span class="arsenal-tag">Cisco: Intro to CyberSecurity</span>
          </div>
        </div>

      </div>
    </section>

    <!-- Operations -->
    <section class="dossier-section">
      <h2 class="section-title fade-up" data-scramble="OPERATIONS">OPERATIONS</h2>
      <ul class="ops-list fade-up">
        <li class="ops-item fade-up">
          <h3 class="ops-title">CTF Player</h3>
          <p class="ops-desc">[3301] N0T F0UND<br>Actively competing in Capture The Flag competitions, specializing in web exploitation, forensics, and privilege escalation.</p>
        </li>
      </ul>
    </section>

    <!-- Communications -->
    <section class="dossier-section">
      <h2 class="section-title fade-up" data-scramble="COMMUNICATIONS">COMMUNICATIONS</h2>
      <div class="arsenal-tags fade-up">
        <a href="https://www.linkedin.com/in/atharva-gawas-valak/" target="_blank" class="arsenal-tag" style="text-decoration: none;">LinkedIn</a>
        <a href="https://github.com/Atharva-G100" target="_blank" class="arsenal-tag" style="text-decoration: none;">GitHub</a>
        <a href="mailto:gawasatharva8@gmail.com" class="arsenal-tag" style="text-decoration: none;">Email</a>
      </div>
    </section>

    <!-- Directives -->
    <section class="dossier-section">
      <h2 class="section-title fade-up" data-scramble="DIRECTIVES">DIRECTIVES</h2>
      <p class="dossier-text fade-up">
        "Trust nothing. Verify everything."
      </p>
      <p class="dossier-text fade-up">
        Every system has a flaw. Every "false positive" is just a misunderstanding of the underlying architecture. Learning is continuous, and the terminal is home.
      </p>
    </section>

  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      
      /* ── Parallax Scroll Effect ────────────────── */
      const parallaxLayers = document.querySelectorAll('.parallax-layer');
      
      window.addEventListener('scroll', () => {
        const scrolled = window.scrollY;
        
        parallaxLayers.forEach(layer => {
          const speed = parseFloat(layer.getAttribute('data-speed'));
          // Move layers up at different speeds based on scroll
          layer.style.transform = `translateY(${scrolled * -speed}px)`;
        });
      });

      /* ── Scramble Text Function ────────────────── */
      function scrambleText(element, finalString) {
        const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%&*';
        let iterations = 0;
        const maxIterations = 10; 
        
        if (element.hasAttribute('data-scrambled')) return;
        element.setAttribute('data-scrambled', 'true');

        const interval = setInterval(() => {
          let scrambled = '';
          for (let i = 0; i < finalString.length; i++) {
            if (finalString[i] === ' ') {
              scrambled += ' ';
            } else {
              scrambled += chars[Math.floor(Math.random() * chars.length)];
            }
          }
          
          element.innerText = scrambled;
          iterations++;

          if (iterations >= maxIterations) {
            clearInterval(interval);
            element.innerText = finalString;
          }
        }, 40); 
      }

      /* ── Intersection Observer ─────────────────── */
      // Handles both Fade-Up animations and Scramble Decryption
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const el = entry.target;
            
            // Trigger Fade-Up
            if (el.classList.contains('fade-up')) {
              el.classList.add('is-visible');
              
              // Only scramble once it becomes visible
              const targetText = el.getAttribute('data-scramble');
              if (targetText) {
                // Add a small delay to the scramble so the fade-in happens first
                setTimeout(() => {
                  scrambleText(el, targetText);
                }, 200);
              }
              
              // Unobserve after animating in once
              observer.unobserve(el);
            }
          }
        });
      }, {
        threshold: 0.1, // Trigger when 10% is visible
        rootMargin: "0px 0px -50px 0px" // Trigger slightly before it hits the bottom
      });

      // Observe all elements with fade-up class
      document.querySelectorAll('.fade-up').forEach(el => {
        observer.observe(el);
      });

      // Initial trigger for elements already in viewport on load
      // (The observer usually catches this automatically, but just in case)
      setTimeout(() => {
        const scrolled = window.scrollY;
        if(scrolled === 0) {
           document.querySelectorAll('.fade-up').forEach(el => {
              const rect = el.getBoundingClientRect();
              if(rect.top < window.innerHeight) {
                 el.classList.add('is-visible');
                 const targetText = el.getAttribute('data-scramble');
                 if(targetText) scrambleText(el, targetText);
                 observer.unobserve(el);
              }
           });
        }
      }, 100);

    });
  </script>
</BaseLayout>
